# Configurações do Banco de Dados
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=my_database

# Usada localmente (fora do Docker) — banco Docker exposto na 5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/my_database"

# Porta da aplicação
PORT=3001

# Chaves de Autenticação JWT (NÃO COLOQUE NO GIT)
JWT_SECRET="super-secret-cat-dnd-key-producao"
JWT_REFRESH_SECRET="super-refresh-secret-dragon-key-producao"
